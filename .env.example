NODE_ENV=development
PORT=8787
DATABASE_URL=postgres://rakkr:rakkr@127.0.0.1:5432/rakkr
RAKKR_CONTROLLER_URL=http://localhost:8787
RAKKR_ALLOW_INSECURE_CONTROLLER=0
RAKKR_WEB_ORIGIN=http://localhost:5173
RAKKR_API_TLS_CERT_PATH=
RAKKR_API_TLS_KEY_PATH=
RAKKR_API_TLS_CA_PATH=
RAKKR_LOCAL_ADMIN_EMAIL=admin@rakkr.local
RAKKR_LOCAL_ADMIN_ID=00000000-0000-4000-8000-000000000001
RAKKR_LOCAL_ADMIN_PASSWORD=rakkr-local-dev-password
RAKKR_LOCAL_ADMIN_NAME=Local Admin
RAKKR_LOCAL_ADMIN_GROUPS=
RAKKR_LOCAL_RESOURCE_GRANTS={"node":["node_x32_test"],"recording":["rec_demo_001"]}
RAKKR_LOCAL_ACCESS_POLICIES=[]
# How long (ms) the auth service keeps honoring in-memory sessions with their
# login-time permissions after the database goes unavailable, before it stops
# trusting that cached access (a bounded window so a revoked user cannot retain
# access for a whole outage). Generous default tolerates transient blips/failover.
RAKKR_AUTH_FALLBACK_GRACE_MS=900000
RAKKR_OIDC_ENABLED=0
RAKKR_OIDC_AZURE_TENANT_ID=
RAKKR_OIDC_CLIENT_ID=
RAKKR_OIDC_CLIENT_SECRET=
RAKKR_OIDC_REDIRECT_URI=http://localhost:8787/api/v1/auth/oidc/callback
RAKKR_OIDC_SCOPES=openid profile email
RAKKR_RECORDING_CACHE_DIR=data/recordings
# Master key for encrypting upload-provider secrets (SMB password, S3 secret key)
# at rest. Set a strong value in production; unset uses an insecure dev fallback.
RAKKR_SECRET_KEY=
# Master key for encrypting node SSH private keys at rest. Falls back to
# RAKKR_SECRET_KEY, then an insecure dev fallback. Set a distinct strong value in
# production.
RAKKR_NODE_SSH_MASTER_KEY=
# Shared token the Ansible runner presents to fetch per-node SSH keys + tokens
# from the controller. Set the SAME value here (controller) and on the runner
# (RAKKR_RUNNER_TOKEN). Unset disables runner credential fetch.
RAKKR_RUNNER_TOKEN=
RAKKR_SCHEDULE_RUNNER_ENABLED=1
RAKKR_SCHEDULE_RUNNER_INTERVAL_SECONDS=30
RAKKR_SCHEDULE_FAILURE_RETRY_SECONDS=300
RAKKR_WATCHDOG_RUNNER_ENABLED=1
RAKKR_WATCHDOG_RUNNER_INTERVAL_SECONDS=30
RAKKR_WATCHDOG_MAX_SAMPLE_SPAN_SECONDS=30
RAKKR_NODE_OFFLINE_AFTER_SECONDS=120
RAKKR_METER_BACKEND=alsa
RAKKR_METER_SAMPLE_SECONDS=1
RAKKR_METER_CLIP_DBFS=-1
RAKKR_METER_FLATLINE_DBFS=-120
RAKKR_AGENT_HEALTH_LOG_FILE=data/agent/health-events.jsonl
RAKKR_AGENT_HEALTH_LOG_MAX_BYTES=1048576
RAKKR_ANSIBLE_RUNNER_URL=http://localhost:8790
RAKKR_ANSIBLE_DEFAULT_SSH_USER=rakkr
RAKKR_ANSIBLE_SSH_PASSWORD=rakkr
RAKKR_ANSIBLE_HOST_OVERRIDES={"node_x32_test":"recorder-test-rig"}
RAKKR_ANSIBLE_TARGETS={"node_x32_test":{"host":"recorder-test-rig","sshUser":"rakkr","sshPassword":"rakkr","becomePassword":"rakkr"}}
RAKKR_ANSIBLE_ROLLOUT_SERIAL=1
RAKKR_ANSIBLE_SSH_DIR=./deploy/ansible/empty-ssh
RAKKR_ANSIBLE_SSH_KEY_FILE=
# Controller-side recorder-agent "update available" check. The controller polls
# GitHub for the newest agent release and the nodes page flags nodes that are
# behind. Independent of the runner's RAKKR_ANSIBLE_AGENT_REPO / GITHUB_TOKEN.
RAKKR_AGENT_RELEASE_REPO=yashau/Rakkr
# RAKKR_GITHUB_TOKEN=            # optional: higher GitHub API rate limits
# RAKKR_AGENT_RELEASE_TTL_MS=1800000
# Runner -> controller credential fetch (preferred over SSH secrets in TARGETS).
# When set, the runner fetches each node's SSH key + token from the controller.
RAKKR_RUNNER_CONTROLLER_URL=
RAKKR_RUNNER_CONTROLLER_CA=
# RAKKR_RUNNER_ALLOW_INSECURE=1   # dev only: skip controller TLS verification
